# ─── Server ──────────────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env.

# Required: your OpenAI API key (https://platform.openai.com/api-keys)
GEMINI_API_KEY=

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
PORT=8080
NODE_ENV=development

# Comma-free single origin, or * for all (tighten this in production)
CORS_ORIGIN=http://localhost:5173

# Rate limiting for POST /api/improve
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# ─── Client (Vite) ───────────────────────────────────────
# Leave blank to call the API on the same origin (recommended in Docker/production).
# Set to http://localhost:8080 only if running client and server on different ports
# without the Vite dev proxy.
VITE_API_URL=
